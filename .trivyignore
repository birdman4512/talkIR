# CVEs in fluent/fluent-bit:3.2 base image packages.
# This image has no shell (/bin/sh absent), so apt-get cannot be run to upgrade
# packages. These are acknowledged base-image findings outside our control.
# Review when upgrading fluent-bit to a newer major version.

# libc6
CVE-2025-4802

# libgnutls30
CVE-2025-32988
CVE-2025-32990

# liblzma5
CVE-2025-31115

# libpq5
CVE-2025-12818
CVE-2025-8714
CVE-2025-8715
CVE-2026-2004
CVE-2026-2005
CVE-2026-2006

# libssl3
CVE-2025-15467
CVE-2025-69419
CVE-2025-69421

# Go stdlib CVEs embedded in /usr/bin/ollama in older upstream builds.
# Review these ignores on each Ollama image upgrade and remove any entries that
# no longer reproduce on the pinned image version in this repo.

# crypto/tls — Unexpected session resumption
CVE-2025-68121

# crypto/x509 — ExtKeyUsageAny disables policy validation
CVE-2025-22874

# database/sql — Postgres scan race condition
CVE-2025-47907

# archive/tar — Unbounded allocation parsing GNU sparse map
CVE-2025-58183

# net/url — Memory exhaustion in query parameter parsing
CVE-2025-61726

# archive/zip — Excessive CPU consumption building archive index
CVE-2025-61728

# crypto/x509 — DoS via excessive resource consumption
CVE-2025-61729

# net/url — Incorrect parsing of IPv6 host literals
CVE-2026-25679
