# Environment — contains real credentials
.env

# Generated TLS certificates
certs/
!certs/.gitkeep

# Log files dropped by users (keep the directory marker)
logs/
!logs/.gitkeep

# Outbound request logs (threat intel, LLM calls)
request_logs/

