__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
coverage.xml
*.egg-info/
dist/
build/
.venv/
venv/

# Docker build artefacts
*.tar

# Fluent Bit tail position database
fluent-bit/*.db
fluent-bit/*.db-shm
fluent-bit/*.db-wal

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db