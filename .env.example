# Stack versions — keep ES and Kibana in sync
STACK_VERSION=8.17.0

# ─── Credentials ──────────────────────────────────────────────────────────────
# Change all three before first run
ELASTIC_PASSWORD=changeme_elastic
KIBANA_PASSWORD=changeme_kibana

# Must be 32+ characters (used for Kibana saved-object encryption)
KIBANA_ENCRYPTION_KEY=changeme_32char_encryption_key_here!!

# ─── Authentication ───────────────────────────────────────────────────────────
# Must be a long random string — used to sign session JWTs.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# ─── Cloud LLM API keys (optional — leave blank to use Ollama only) ───────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Threat intelligence API keys (optional) ──────────────────────────────────
# AbuseIPDB — free tier: 1 000 lookups/day — https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=
# VirusTotal — free tier: 500 lookups/day, 4/min — https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# ─── LLM ──────────────────────────────────────────────────────────────────────
# CPU-friendly options (in order of quality vs. speed trade-off):
#   qwen2.5:7b            — strongest default for structured queries
#   llama3.2:3b           — best low-memory fallback
#   mistral:7b-instruct   — good all-rounder, slower on CPU
OLLAMA_IMAGE=ollama/ollama:0.13.5
OLLAMA_MODEL=qwen2.5:7b


# ─── Ports ────────────────────────────────────────────────────────────────────
ES_PORT=9200
KIBANA_PORT=5601
OLLAMA_PORT=11434
FRONTEND_PORT=3000

# ─── Kibana mTLS client certificate ──────────────────────────────────────────
# Paths are relative to Kibana's config directory (/usr/share/kibana/config/).
# These match the cert names generated by the setup container — only change if
# you supply your own certificates.
KIBANA_ES_CERT=config/certs/kibana/kibana.crt
KIBANA_ES_KEY=config/certs/kibana/kibana.key

# ─── Resource limits ──────────────────────────────────────────────────────────
# ES + Kibana memory limit (bytes). 1 GB = 1073741824
MEM_LIMIT=1073741824

# License type: basic (free) or trial (30-day trial with all features)
LICENSE=basic
